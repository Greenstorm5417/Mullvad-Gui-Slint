pkgname=mullvad-gui-slint
pkgver=0.1.0_alpha.1
pkgrel=1
pkgdesc='Native Slint frontend for the Mullvad VPN daemon'
arch=('x86_64' 'aarch64')
url='https://github.com/Greenstorm5417/Mullvad-Gui-Slint'
license=('GPL-3.0-or-later')
depends=('fontconfig' 'libxkbcommon')
optdepends=('mullvad-vpn: official Mullvad daemon and VPN service')
makedepends=('cargo' 'rust')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v${pkgver/_/-}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "Mullvad-Gui-Slint-${pkgver/_/-}"
  cargo build --locked --release
}

check() {
  cd "Mullvad-Gui-Slint-${pkgver/_/-}"
  cargo test --locked --all-features
}

package() {
  cd "Mullvad-Gui-Slint-${pkgver/_/-}"
  DESTDIR="$pkgdir" PREFIX=/usr ./scripts/stage-linux.sh
}
