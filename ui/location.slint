import { ListView, ScrollView } from "std-widgets.slint";
import { ThinScrollbar } from "scrollbar.slint";
import "../assets/fonts/OpenSans-Regular.ttf";
import "../assets/fonts/OpenSans-Semibold.ttf";
import "../assets/fonts/OpenSans-Bold.ttf";
import "../assets/fonts/SourceSansPro-SemiBold.ttf";
import "../assets/fonts/SourceSansPro-Bold.ttf";

export struct LocationRowData {
    label: string,
    depth: int,
    source-index: int,
    expandable: bool,
    expanded: bool,
    selected: bool,
    disabled: bool,
    visible: bool,
    has-menu: bool,
    last-in-section: bool,
    joined-above: bool,
    joined-below: bool,
    section-start: bool,
    section-title: string,
    section-detail: string,
    subtitle: string,
    placeholder: bool,
    section-end: bool,
    can-add-to-list: bool,
    location-type: string,
}

export struct LocationFilterChip {
    id: string,
    label: string,
}

export struct ProviderFilterData {
    name: string,
    selected: bool,
}

export struct CustomListLocationData {
    label: string,
    depth: int,
    source-index: int,
    selected: bool,
}

export struct CustomListChoiceData {
    label: string,
    list-source-index: int,
    selected: bool,
}

global LocationColors {
    out property <color> white: #ffffff;
    out property <color> white-80: #ffffffcc;
    out property <color> white-60: #ffffff99;
    out property <color> white-40: #ffffff66;
    out property <color> white-20: #ffffff33;
    out property <color> green: #44ad4d;
    out property <color> blue: #294d73;
    out property <color> blue-60: #234161;
    out property <color> blue-40: #1f3a57;
    out property <color> blue-20: #1c344e;
    out property <color> blue-hover: #3e5f81;
    out property <color> blue-pressed: #54718f;
    out property <color> dark-blue: #192e45;
    out property <color> chalk: #f8f7f1;
}

component LocationIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> accessible-name;
    in property <bool> enabled: true;
    callback clicked;
    width: 24px;
    height: 24px;
    border-radius: 12px;
    background: touch.pressed ? #ffffff1a : transparent;
    forward-focus: keyboard;
    accessible-role: button;
    accessible-label: root.accessible-name;
    accessible-enabled: root.enabled;
    accessible-action-default => { root.clicked(); }

    Image {
        width: 24px;
        height: 24px;
        source: root.icon;
        image-fit: contain;
        opacity: !root.enabled ? 0.4 : touch.pressed ? 1 : touch.has-hover ? 0.8 : 0.6;
        animate opacity {
            duration: 150ms;
            easing: ease;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    keyboard := FocusScope {
        x: 0;
        width: 0;
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
}

component LocationChevronButton inherits Rectangle {
    in property <bool> expanded;
    in property <bool> enabled: true;
    callback clicked;
    width: 48px;
    border-radius: 16px;
    background: !root.enabled ? transparent : touch.pressed ? LocationColors.blue-pressed : touch.has-hover ? LocationColors.blue-hover : transparent;

    Image {
        x: (parent.width - 24px) / 2;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        source: root.expanded ? @image-url("../assets/icons/icon-chevron-up.svg") : @image-url("../assets/icons/icon-chevron-down.svg");
        image-fit: contain;
        opacity: root.enabled ? 1 : 0.4;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component ScopeBar inherits Rectangle {
    in-out property <int> selected-index;
    callback changed(int);
    height: 28px;
    border-radius: 13px;
    clip: true;
    background: LocationColors.blue-40;

    Rectangle {
        width: parent.width / 2;
        height: parent.height;
        background: root.selected-index == 0 ? LocationColors.green : entry-touch.has-hover ? LocationColors.blue-40 : transparent;
        Text {
            text: "Entry";
            color: LocationColors.white;
            font-family: "Open Sans";
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        entry-touch := TouchArea {
            clicked => { root.selected-index = 0; root.changed(0); }
        }
    }

    Rectangle {
        x: parent.width / 2;
        width: parent.width / 2;
        height: parent.height;
        background: root.selected-index == 1 ? LocationColors.green : exit-touch.has-hover ? LocationColors.blue-40 : transparent;
        Text {
            text: "Exit";
            color: LocationColors.white;
            font-family: "Open Sans";
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        exit-touch := TouchArea {
            clicked => { root.selected-index = 1; root.changed(1); }
        }
    }
}

component FilterChip inherits Rectangle {
    in property <string> label;
    callback removed;
    height: 24px;
    min-width: 48px;
    border-radius: 12px;
    background: chip-touch.pressed ? LocationColors.blue-pressed : chip-touch.has-hover ? LocationColors.blue-hover : LocationColors.blue;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 4px;
        spacing: 2px;
        Text {
            text: root.label;
            color: LocationColors.white;
            font-family: "Open Sans";
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        Image {
            width: 18px;
            height: 18px;
            source: @image-url("../assets/icons/icon-cross.svg");
            image-fit: contain;
            opacity: 0.8;
        }
    }

    chip-touch := TouchArea {
        clicked => { root.removed(); }
    }
}

component SearchField inherits Rectangle {
    in-out property <string> text;
    callback search-changed(string);
    height: 32px;
    border-radius: 12px;
    background: LocationColors.blue-40;
    border-width: input.has-focus ? 2px : 1px;
    border-color: input.has-focus ? LocationColors.chalk : LocationColors.white-40;

    Image {
        x: 8px;
        y: 7px;
        width: 18px;
        height: 18px;
        source: @image-url("../assets/icons/icon-search.svg");
        image-fit: contain;
        opacity: 0.6;
    }

    Text {
        visible: input.text == "";
        x: 30px;
        width: parent.width - 68px;
        height: parent.height;
        text: "Search locations or servers";
        color: LocationColors.white-60;
        font-family: "Open Sans";
        font-size: 14px;
        vertical-alignment: center;
        overflow: elide;
    }

    input := TextInput {
        x: 30px;
        width: parent.width - 68px;
        height: parent.height;
        text: root.text;
        color: LocationColors.white;
        font-family: "Open Sans";
        font-size: 14px;
        vertical-alignment: center;
        single-line: true;
        edited => {
            root.text = self.text;
            search-delay.running = false;
            search-delay.running = true;
        }
        accepted => {
            search-delay.running = false;
            root.search-changed(self.text.character-count >= 2 ? self.text.to-lowercase() : "");
        }
    }

    LocationIconButton {
        visible: root.text != "";
        x: parent.width - 28px;
        y: 4px;
        icon: @image-url("../assets/icons/icon-cross-circle.svg");
        clicked => {
            search-delay.running = false;
            root.text = "";
            input.text = "";
            root.search-changed("");
            input.focus();
        }
    }

    search-delay := Timer {
        interval: 200ms;
        running: false;
        triggered => {
            self.running = false;
            root.search-changed(root.text.character-count >= 2 ? root.text.to-lowercase() : "");
        }
    }
}

component SectionHeading inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> action-visible: false;
    callback action;
    height: 30px;
    background: transparent;
    Text {
        x: 0;
        y: 0;
        height: 18px;
        text: root.title;
        color: LocationColors.white;
        font-family: "Open Sans";
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }

    Rectangle {
        x: title-text.preferred-width + 8px;
        y: 8px;
        width: parent.width - self.x - (root.detail == "" ? 0px : detail-text.width + 8px) - (root.action-visible ? 32px : 0px);
        height: 1px;
        background: LocationColors.white-20;
    }

    title-text := Text {
        visible: false;
        text: root.title;
        font-family: "Open Sans";
        font-size: 12px;
        font-weight: 600;
    }

    detail-text := Text {
        visible: root.detail != "";
        x: parent.width - 96px;
        y: 0;
        width: 96px;
        height: 18px;
        text: root.detail;
        color: LocationColors.white-60;
        font-family: "Open Sans";
        font-size: 12px;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }

    LocationIconButton {
        visible: root.action-visible;
        x: parent.width - 24px;
        y: -3px;
        icon: @image-url("../assets/icons/icon-add.svg");
        clicked => { root.action(); }
    }
}

component FilterAccordionHeader inherits Rectangle {
    in property <string> label;
    in property <bool> open;
    callback clicked;
    height: 48px;
    border-radius: 16px;
    background: header-touch.pressed ? LocationColors.blue-pressed : header-touch.has-hover ? LocationColors.blue-hover : LocationColors.blue;
    Rectangle {
        visible: root.open;
        y: 24px;
        width: parent.width;
        height: 24px;
        background: parent.background;
    }

    Text {
        x: 16px;
        width: parent.width - 64px;
        height: parent.height;
        text: root.label;
        color: LocationColors.white;
        font-family: "Open Sans";
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
    }

    Image {
        x: parent.width - 40px;
        y: 12px;
        width: 24px;
        height: 24px;
        source: root.open ? @image-url("../assets/icons/icon-chevron-up.svg") : @image-url("../assets/icons/icon-chevron-down.svg");
        image-fit: contain;
        opacity: 0.8;
    }

    header-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component FilterRadioRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> last;
    callback clicked;
    height: 48px;
    border-radius: root.last ? 16px : 0px;
    background: row-touch.pressed ? LocationColors.blue-pressed : row-touch.has-hover ? LocationColors.blue-hover : LocationColors.blue-60;
    Rectangle {
        visible: root.last;
        width: parent.width;
        height: 24px;
        background: parent.background;
    }

    Image {
        visible: root.selected;
        x: 16px;
        y: 12px;
        width: 24px;
        height: 24px;
        source: @image-url("../assets/icons/icon-checkmark.svg");
        image-fit: contain;
    }

    Text {
        x: 48px;
        width: parent.width - 64px;
        height: parent.height;
        text: root.label;
        color: LocationColors.white;
        font-family: "Open Sans";
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    row-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component FilterCheckboxRow inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    in property <bool> last;
    callback clicked;
    height: 48px;
    border-radius: root.last ? 16px : 0px;
    background: row-touch.pressed ? LocationColors.blue-pressed : row-touch.has-hover ? LocationColors.blue-hover : LocationColors.blue-60;
    Rectangle {
        visible: root.last;
        width: parent.width;
        height: 24px;
        background: parent.background;
    }

    Rectangle {
        x: 16px;
        y: 14px;
        width: 20px;
        height: 20px;
        border-radius: 4px;
        border-width: root.checked ? 0px : 2px;
        border-color: LocationColors.white-60;
        background: root.checked ? LocationColors.green : transparent;
        Image {
            visible: root.checked;
            x: -2px;
            y: -2px;
            width: 24px;
            height: 24px;
            source: @image-url("../assets/icons/icon-checkmark.svg");
            image-fit: contain;
        }
    }

    Text {
        x: 48px;
        width: parent.width - 64px;
        height: parent.height;
        text: root.label;
        color: LocationColors.white;
        font-family: "Open Sans";
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    row-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component LocationListRow inherits Rectangle {
    in property <LocationRowData> data;
    callback selected(int);
    callback toggled(int);
    callback menu-clicked(int);
    callback add-to-list(int, string);
    callback add-custom-list;

    private property <length> content-height: root.data.placeholder ? 18px : root.data.subtitle == "" ? 48px : 52px;
    private property <length> item-spacing: root.data.placeholder ? 0px : root.data.joined-below ? 1px : 4px;
    height: root.data.visible ? (root.data.section-start ? 34px : 0px) + content-height + item-spacing + (root.data.section-end ? 24px : 0px) : 0px;
    opacity: root.data.visible ? 1 : 0;
    clip: true;
    background: transparent;
    animate height {
        duration: 250ms;
        easing: ease-in-out;
    }
    animate opacity {
        duration: 250ms;
        easing: ease-in-out;
    }

    private property <color> row-color: !root.data.disabled
        ? (select-touch.pressed ? LocationColors.blue-pressed
        : select-touch.has-hover ? LocationColors.blue-hover
        : root.data.depth == 0 ? LocationColors.blue
        : root.data.depth == 1 ? LocationColors.blue-60
        : LocationColors.blue-40)
        : root.data.depth == 0 ? LocationColors.blue-40
        : root.data.depth == 1 ? LocationColors.blue-40
        : LocationColors.blue-20;

    SectionHeading {
        visible: root.data.section-start;
        y: 0;
        width: parent.width;
        title: root.data.section-title;
        detail: root.data.section-detail;
        action-visible: root.data.section-title == "Custom lists";
        action => { root.add-custom-list(); }
    }

    private property <length> row-y: root.data.section-start ? 34px : 0px;

    Rectangle {
        visible: !root.data.placeholder && root.data.joined-above;
        y: root.row-y;
        width: parent.width;
        height: 24px;
        background: root.row-color;
    }

    Rectangle {
        visible: !root.data.placeholder && root.data.joined-below;
        y: root.row-y + root.content-height - 24px;
        width: parent.width;
        height: 24px;
        background: root.row-color;
    }

    row-background := Rectangle {
        visible: !root.data.placeholder;
        y: root.row-y;
        width: parent.width;
        height: root.content-height;
        border-radius: 16px;
        background: root.row-color;
        accessible-role: list-item;
        accessible-label: root.data.label;
        accessible-enabled: !root.data.disabled;
        accessible-action-default => { root.selected(root.data.source-index); }

        Image {
            x: 16px + root.data.depth * 16px + (root.data.selected ? 0px : -16px);
            y: 12px;
            width: 24px;
            height: 24px;
            source: @image-url("../assets/icons/icon-checkmark.svg");
            image-fit: contain;
            opacity: !root.data.selected ? 0 : root.data.disabled ? 0.4 : 1;
            animate x {
                duration: 150ms;
                easing: ease-out;
            }
            animate opacity {
                duration: 150ms;
                easing: ease-in;
            }
        }

        Text {
            x: 16px + root.data.depth * 16px + (root.data.selected ? 32px : 0px);
            width: parent.width - self.x - (root.data.has-menu ? 48px : 0px) - (root.data.can-add-to-list ? 48px : 0px) - (root.data.expandable ? 48px : 0px) - 16px;
            y: root.data.subtitle == "" ? 0px : 5px;
            height: root.data.subtitle == "" ? parent.height : 20px;
            text: root.data.label;
            color: root.data.disabled ? LocationColors.white-40 : root.data.selected ? LocationColors.green : LocationColors.white;
            font-family: "Open Sans";
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
            animate x {
                duration: 150ms;
                easing: ease-out;
            }
        }

        Text {
            visible: root.data.subtitle != "";
            x: 16px + root.data.depth * 16px + (root.data.selected ? 32px : 0px);
            y: 28px;
            width: parent.width - self.x - 16px;
            height: 15px;
            text: root.data.subtitle;
            color: LocationColors.white-60;
            font-family: "Open Sans";
            font-size: 10px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
            animate x {
                duration: 150ms;
                easing: ease-out;
            }
        }

        select-touch := TouchArea {
            width: parent.width - (root.data.has-menu ? 48px : 0px) - (root.data.can-add-to-list ? 48px : 0px) - (root.data.expandable ? 48px : 0px);
            enabled: !root.data.disabled;
            clicked => { root.selected(root.data.source-index); }
        }

        LocationIconButton {
            visible: root.data.has-menu;
            x: parent.width - (root.data.expandable ? 84px : 36px);
            y: 12px;
            enabled: !root.data.disabled;
            icon: @image-url("../assets/icons/icon-more-horizontal.svg");
            clicked => { root.menu-clicked(root.data.source-index); }
        }

        LocationIconButton {
            visible: root.data.can-add-to-list;
            x: parent.width - (root.data.expandable ? 84px : 36px);
            y: 12px;
            enabled: !root.data.disabled;
            icon: @image-url("../assets/icons/icon-add-circle.svg");
            clicked => { root.add-to-list(root.data.source-index, root.data.location-type); }
        }

        LocationChevronButton {
            visible: root.data.expandable;
            x: parent.width - 48px;
            y: 0;
            height: parent.height;
            enabled: !root.data.disabled;
            expanded: root.data.expanded;
            clicked => { root.toggled(root.data.source-index); }
        }
    }

    Text {
        visible: root.data.placeholder;
        x: 0;
        y: root.data.section-start ? 34px : 0px;
        width: parent.width;
        height: 18px;
        text: root.data.label;
        color: LocationColors.white-60;
        font-family: "Open Sans";
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component LocationPage inherits Rectangle {
    width: 320px;
    height: 568px;
    in property <[LocationRowData]> rows;
    in property <[LocationFilterChip]> active-filters;
    in-out property <string> search-text: "";
    in property <bool> show-entry-exit: false;
    in-out property <int> location-type: 1; // 0 entry, 1 exit
    in property <bool> searching: false;
    in property <int> multihop-mode: 0;
    in property <bool> recents-enabled: true;
    in property <[ProviderFilterData]> providers;
    in property <[CustomListLocationData]> custom-list-locations;
    in property <[CustomListChoiceData]> custom-list-choices;
    in property <int> ownership-filter: -1; // -1 any, 0 owned, 1 rented
    in property <int> selected-provider-count: 0;
    in property <string> initial-overlay: "";
    in-out property <length> list-viewport-y <=> relay-list-view.viewport-y;
    callback back;
    callback menu;
    callback select(int);
    callback toggle(int);
    callback row-menu(int);
    callback search-changed(string);
    callback location-type-changed(int);
    callback remove-filter(string);
    callback multihop-changed(int);
    callback recents-changed(bool);
    callback filter-clicked;
    callback provider-toggled(string, bool);
    callback providers-select-all(bool);
    callback ownership-changed(int);
    callback apply-filters;
    callback create-custom-list(string);
    callback rename-custom-list(int, string);
    callback delete-custom-list(int);
    callback edit-custom-list(int);
    callback custom-list-location-toggled(int, int, bool);
    callback prepare-add-location(int);
    callback add-location-to-custom-list(int, int);

    private property <bool> menu-open: root.initial-overlay == "menu";
    private property <bool> filter-open: root.initial-overlay == "filter";
    private property <bool> add-list-open: root.initial-overlay == "create-list";
    private property <string> list-name: "";
    private property <int> custom-menu-index: -1;
    private property <bool> rename-list-open: false;
    private property <bool> edit-list-open: false;
    private property <int> edit-list-index: -1;
    private property <bool> ownership-open: true;
    private property <bool> providers-open: true;
    private property <bool> disable-recents-open: false;
    private property <bool> delete-list-open: false;
    private property <bool> add-location-open: false;
    private property <int> add-location-source-index: -1;
    private property <string> add-location-type: "Location";

    background: LocationColors.dark-blue;

    Rectangle {
        x: 0;
        y: 0;
        z: 10;
        width: parent.width;
        height: 72px;
        background: LocationColors.dark-blue;
        LocationIconButton {
            x: 16px;
            y: 20px;
            icon: @image-url("../assets/icons/icon-chevron-down-circle.svg");
            accessible-name: "Close";
            clicked => { root.back(); }
        }

        Text {
            x: 56px;
            y: 24px;
            width: parent.width - 112px;
            height: 24px;
            text: "Select location";
            color: LocationColors.white;
            font-family: "Source Sans Pro";
            font-size: 18px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }

        LocationIconButton {
            x: parent.width - 48px;
            y: 20px;
            icon: @image-url("../assets/icons/icon-more-horizontal-circle.svg");
            accessible-name: "Location settings";
            clicked => { root.menu-open = !root.menu-open; root.menu(); }
        }
    }

    Rectangle {
        x: 16px;
        y: 72px;
        width: parent.width - 32px;
        height: controls-height;
        background: LocationColors.dark-blue;

        ScopeBar {
            visible: root.show-entry-exit;
            x: 0;
            y: 0;
            width: parent.width;
            selected-index: root.location-type;
            changed(index) => { root.location-type = index; root.location-type-changed(index); }
        }

        HorizontalLayout {
            visible: root.active-filters.length > 0;
            y: root.show-entry-exit ? 44px : 0px;
            width: parent.width;
            height: 24px;
            spacing: 8px;
            Text {
                text: "Filtered:";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 12px;
                font-weight: 600;
                vertical-alignment: center;
            }

            for chip in root.active-filters: FilterChip {
                label: chip.label;
                horizontal-stretch: 1;
                removed => { root.remove-filter(chip.id); }
            }
        }

        SearchField {
            y: (root.show-entry-exit ? 44px : 0px) + (root.active-filters.length > 0 ? 40px : 0px);
            width: parent.width;
            text: root.search-text;
            search-changed(value) => { root.search-text = self.text; root.search-changed(value); }
        }
    }

    private property <length> controls-height: (root.show-entry-exit ? 44px : 0px) + (root.active-filters.length > 0 ? 40px : 0px) + 40px;

    relay-list-view := ListView {
        x: 16px;
        y: 72px + controls-height + 8px;
        width: parent.width - 32px;
        height: parent.height - self.y - 24px;
        horizontal-scrollbar-policy: always-off;
        vertical-scrollbar-policy: always-off;
        for row in root.rows: LocationListRow {
            width: parent.width;
            data: row;
            selected(index) => { root.select(index); }
            toggled(index) => { root.toggle(index); }
            menu-clicked(index) => { root.custom-menu-index = index; root.list-name = row.label; root.row-menu(index); }
            add-to-list(index, location-type) => { root.add-location-source-index = index; root.add-location-type = location-type; root.prepare-add-location(index); root.add-location-open = true; }
            add-custom-list => { root.list-name = ""; root.add-list-open = true; }
        }
    }

    // Upstream's scrollbar track is an absolutely-positioned overlay flush
    // with the scrollable area's own right edge (it floats over the content's
    // rightmost pixels, not squeezed into an extra reserved gutter beside it).
    ThinScrollbar {
        x: relay-list-view.x + relay-list-view.width - 12px;
        y: relay-list-view.y;
        width: 12px;
        height: relay-list-view.height;
        content-height: relay-list-view.viewport-height;
        visible-height: relay-list-view.visible-height;
        scroll-y <=> relay-list-view.viewport-y;
    }

    Text {
        visible: root.searching;
        x: 16px;
        y: 72px + controls-height + 32px;
        width: parent.width - 32px;
        height: 20px;
        text: "Searching...";
        color: LocationColors.white-60;
        font-family: "Open Sans";
        font-size: 14px;
        horizontal-alignment: center;
    }

    menu-overlay := Rectangle {
        visible: root.menu-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 100;
        background: #00000000;
        TouchArea {
            clicked => { root.menu-open = false; }
        }

        Rectangle {
            x: parent.width - 232px;
            y: 56px;
            width: 216px;
            height: 274px;
            border-radius: 4px;
            clip: true;
            background: LocationColors.blue;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000066;
            drop-shadow-offset-y: 4px;

            menu-filter := Rectangle {
                width: parent.width;
                height: 48px;
                background: filter-touch.has-hover ? #ffffff14 : transparent;
                Image {
                    x: 16px;
                    y: 14px;
                    width: 20px;
                    height: 20px;
                    source: @image-url("../assets/icons/icon-filter.svg");
                    image-fit: contain;
                }

                Text {
                    x: 48px;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: "Filters";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                filter-touch := TouchArea {
                    clicked => { root.menu-open = false; root.filter-open = true; root.filter-clicked(); }
                }
            }

            Text {
                x: 16px;
                y: 48px;
                width: parent.width - 32px;
                height: 30px;
                text: "MULTIHOP MODE";
                color: LocationColors.white-60;
                font-family: "Open Sans";
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
            }

            for mode[index] in ["When needed", "Always", "Never"]: Rectangle {
                y: 78px + index * 44px;
                width: parent.width;
                height: 44px;
                background: mode-touch.has-hover ? #ffffff14 : transparent;
                Text {
                    x: 16px;
                    width: 20px;
                    height: parent.height;
                    text: root.multihop-mode == index ? "✓" : "";
                    color: LocationColors.green;
                    font-family: "Open Sans";
                    font-size: 16px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }

                Text {
                    x: 48px;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: mode;
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                mode-touch := TouchArea {
                    clicked => { root.menu-open = false; root.multihop-changed(index); }
                }
            }
            Rectangle {
                y: 210px;
                width: parent.width;
                height: 1px;
                background: #ffffff1f;
            }

            recents-row := Rectangle {
                y: 211px;
                width: parent.width;
                height: 63px;
                background: recents-touch.has-hover ? #ffffff14 : transparent;
                Image {
                    x: 16px;
                    y: 21px;
                    width: 20px;
                    height: 20px;
                    source: @image-url("../assets/icons/icon-history-remove.svg");
                    image-fit: contain;
                }

                Text {
                    x: 48px;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: root.recents-enabled ? "Disable recents" : "Enable recents";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                recents-touch := TouchArea {
                    clicked => { root.menu-open = false; if (root.recents-enabled) { root.disable-recents-open = true; } else { root.recents-changed(true); } }
                }
            }
        }
    }

    disable-recents-overlay := Rectangle {
        visible: root.disable-recents-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 150;
        background: #00000080;
        TouchArea { }

        Rectangle {
            x: 16px;
            y: (parent.height - 248px) / 2;
            width: parent.width - 32px;
            height: 248px;
            border-radius: 12px;
            background: LocationColors.dark-blue;
            Image {
                x: (parent.width - 48px) / 2;
                y: 24px;
                width: 48px;
                height: 48px;
                source: @image-url("../assets/icons/icon-info-circle.svg");
                image-fit: contain;
            }

            Text {
                x: 16px;
                y: 88px;
                width: parent.width - 32px;
                height: 44px;
                text: "Disabling recents will also clear history.";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 14px;
                font-weight: 600;
                wrap: word-wrap;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Rectangle {
                x: 16px;
                y: 144px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: #e34039;
                Text {
                    text: "Disable";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.recents-changed(false); root.disable-recents-open = false; }
                }
            }

            Rectangle {
                x: 16px;
                y: 192px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                Text {
                    text: "Cancel";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.disable-recents-open = false; }
                }
            }
        }
    }

    filter-overlay := Rectangle {
        visible: root.filter-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 120;
        background: LocationColors.dark-blue;
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: 72px;
            background: LocationColors.dark-blue;
            LocationIconButton {
                x: 16px;
                y: 20px;
                icon: @image-url("../assets/icons/icon-chevron-left-circle.svg");
                accessible-name: "Back";
                clicked => { root.filter-open = false; }
            }

            Text {
                x: 56px;
                y: 24px;
                width: parent.width - 112px;
                height: 24px;
                text: "Filter";
                color: LocationColors.white;
                font-family: "Source Sans Pro";
                font-size: 18px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        filter-scroll := ScrollView {
            x: 16px;
            y: 72px;
            width: parent.width - 32px;
            height: parent.height - 160px;
            horizontal-scrollbar-policy: always-off;
            vertical-scrollbar-policy: always-off;
            viewport-x: 0px;
            viewport-y: 0px;
            viewport-width: self.width;
            viewport-height: provider-group.y + provider-group.height;
            ownership-group := Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 48px + (root.ownership-open ? 144px : 0px);
                FilterAccordionHeader {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    label: "Ownership";
                    open: root.ownership-open;
                    clicked => { root.ownership-open = !root.ownership-open; }
                }

                if root.ownership-open: Rectangle {
                    x: 0;
                    y: 49px;
                    width: parent.width;
                    height: 143px;
                    for label[index] in ["Any", "Mullvad owned only", "Rented only"]: FilterRadioRow {
                        y: index * 48px;
                        width: parent.width;
                        label: label;
                        selected: root.ownership-filter == index - 1;
                        last: index == 2;
                        clicked => { root.ownership-changed(index - 1); }
                    }
                }
            }

            provider-group := Rectangle {
                x: 0;
                y: ownership-group.height + 8px;
                width: parent.width;
                height: 48px + (root.providers-open ? (root.providers.length + 1) * 48px : 0px);
                FilterAccordionHeader {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    label: "Providers";
                    open: root.providers-open;
                    clicked => { root.providers-open = !root.providers-open; }
                }

                if root.providers-open: Rectangle {
                    x: 0;
                    y: 49px;
                    width: parent.width;
                    height: (root.providers.length + 1) * 48px - 1px;
                    FilterCheckboxRow {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        label: "All providers";
                        checked: root.selected-provider-count == root.providers.length;
                        last: root.providers.length == 0;
                        clicked => { root.providers-select-all(root.selected-provider-count != root.providers.length); }
                    }

                    for provider[index] in root.providers: FilterCheckboxRow {
                        y: (index + 1) * 48px;
                        width: parent.width;
                        label: provider.name;
                        checked: provider.selected;
                        last: index == root.providers.length - 1;
                        clicked => { root.provider-toggled(provider.name, !provider.selected); }
                    }
                }
            }
        }

        ThinScrollbar {
            x: filter-scroll.x + filter-scroll.width - 12px;
            y: filter-scroll.y;
            width: 12px;
            height: filter-scroll.height;
            content-height: filter-scroll.viewport-height;
            visible-height: filter-scroll.visible-height;
            scroll-y <=> filter-scroll.viewport-y;
        }

        apply-button := Rectangle {
            x: 16px;
            y: parent.height - 64px;
            width: parent.width - 32px;
            height: 40px;
            border-radius: 4px;
            background: LocationColors.green;
            opacity: root.selected-provider-count > 0 ? 1 : 0.4;
            Text {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                text: root.selected-provider-count > 0 ? "Apply" : "No matching servers found";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            TouchArea {
                enabled: root.selected-provider-count > 0;
                clicked => { root.apply-filters(); root.filter-open = false; }
            }
        }
    }

    add-list-overlay := Rectangle {
        visible: root.add-list-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 130;
        background: #00000080;
        TouchArea { }

        Rectangle {
            x: 16px;
            y: (parent.height - 240px) / 2;
            width: parent.width - 32px;
            height: 240px;
            border-radius: 12px;
            background: LocationColors.dark-blue;
            Text {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: 18px;
                text: "Create list";
                color: LocationColors.white-60;
                font-family: "Open Sans";
                font-size: 12px;
                font-weight: 600;
            }

            Rectangle {
                x: 16px;
                y: 42px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                TextInput {
                    x: 8px;
                    y: 8px;
                    width: parent.width - 16px;
                    height: 24px;
                    text: root.list-name;
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    edited => { root.list-name = self.text; }
                }
            }

            Text {
                x: 16px;
                y: 90px;
                width: parent.width - 32px;
                height: 18px;
                text: "Enter a name for the list";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 12px;
            }

            Rectangle {
                x: 16px;
                y: 128px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.green;
                opacity: root.list-name != "" ? 1 : 0.4;
                Text {
                    text: "Create";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    enabled: root.list-name != "";
                    clicked => { root.create-custom-list(root.list-name); root.add-list-open = false; }
                }
            }

            Rectangle {
                x: 16px;
                y: 176px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                Text {
                    text: "Cancel";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.add-list-open = false; }
                }
            }
        }
    }

    add-location-overlay := Rectangle {
        visible: root.add-location-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 135;
        background: #00000080;
        TouchArea { }

        Rectangle {
            x: 16px;
            y: (parent.height - Math.min(360px, 152px + root.custom-list-choices.length * 56px)) / 2;
            width: parent.width - 32px;
            height: Math.min(360px, 152px + root.custom-list-choices.length * 56px);
            border-radius: 12px;
            background: LocationColors.dark-blue;
            Text {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: 28px;
                text: "Add " + root.add-location-type + " to list";
                color: LocationColors.white;
                font-family: "Source Sans Pro";
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            add-location-list := ListView {
                x: 16px;
                y: 60px;
                width: parent.width - 32px;
                height: Math.min(224px, root.custom-list-choices.length * 56px);
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: always-off;
                for choice in root.custom-list-choices: Rectangle {
                    height: 56px;
                    background: choice-touch.has-hover && !choice.selected ? LocationColors.blue-hover : LocationColors.blue;
                    border-radius: 16px;
                    Text {
                        x: 16px;
                        width: parent.width - 64px;
                        height: parent.height;
                        text: choice.label;
                        color: choice.selected ? LocationColors.green : LocationColors.white;
                        font-family: "Open Sans";
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    Image {
                        x: parent.width - 40px;
                        y: 16px;
                        width: 24px;
                        height: 24px;
                        source: choice.selected ? @image-url("../assets/icons/icon-checkmark.svg") : @image-url("../assets/icons/icon-add-circle.svg");
                        image-fit: contain;
                        opacity: choice.selected ? 1 : 0.8;
                    }

                    choice-touch := TouchArea {
                        enabled: !choice.selected;
                        clicked => { root.add-location-to-custom-list(choice.list-source-index, root.add-location-source-index); root.add-location-open = false; }
                    }
                }
            }

            ThinScrollbar {
                x: add-location-list.x + add-location-list.width - 12px;
                y: add-location-list.y;
                width: 12px;
                height: add-location-list.height;
                content-height: add-location-list.viewport-height;
                visible-height: add-location-list.visible-height;
                scroll-y <=> add-location-list.viewport-y;
            }

            Rectangle {
                x: 16px;
                y: parent.height - 56px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                Text {
                    text: "Close";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.add-location-open = false; root.add-location-source-index = -1; }
                }
            }
        }
    }

    custom-menu-overlay := Rectangle {
        visible: root.custom-menu-index >= 0;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 130;
        background: #00000000;
        TouchArea {
            clicked => { root.custom-menu-index = -1; }
        }

        Rectangle {
            x: parent.width - 180px;
            y: 96px;
            width: 164px;
            height: 96px;
            border-radius: 4px;
            clip: true;
            background: LocationColors.blue;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000066;
            drop-shadow-offset-y: 4px;
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 48px;
                background: edit-touch.has-hover ? #ffffff14 : transparent;
                Image {
                    x: 16px;
                    y: 12px;
                    width: 24px;
                    height: 24px;
                    source: @image-url("../assets/icons/icon-edit.svg");
                    image-fit: contain;
                }

                Text {
                    x: 48px;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: "Edit name";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                edit-touch := TouchArea {
                    clicked => { root.rename-list-open = true; }
                }
            }

            Rectangle {
                y: 48px;
                width: parent.width;
                height: 48px;
                background: delete-touch.has-hover ? #ffffff14 : transparent;
                Image {
                    x: 16px;
                    y: 12px;
                    width: 24px;
                    height: 24px;
                    source: @image-url("../assets/icons/icon-trash.svg");
                    image-fit: contain;
                }

                Text {
                    x: 48px;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: "Delete";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                delete-touch := TouchArea {
                    clicked => { root.delete-list-open = true; }
                }
            }
        }
    }

    delete-list-overlay := Rectangle {
        visible: root.delete-list-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 145;
        background: #00000080;
        TouchArea { }

        Rectangle {
            x: 16px;
            y: (parent.height - 268px) / 2;
            width: parent.width - 32px;
            height: 268px;
            border-radius: 12px;
            background: LocationColors.dark-blue;
            Image {
                x: (parent.width - 48px) / 2;
                y: 24px;
                width: 48px;
                height: 48px;
                source: @image-url("../assets/icons/icon-alert-circle.svg");
                image-fit: contain;
            }

            Text {
                x: 16px;
                y: 88px;
                width: parent.width - 32px;
                height: 60px;
                text: "Do you want to delete the list “" + root.list-name + "”?";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 14px;
                font-weight: 600;
                wrap: word-wrap;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Rectangle {
                x: 16px;
                y: 164px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: #e34039;
                Text {
                    text: "Delete list";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.delete-custom-list(root.custom-menu-index); root.delete-list-open = false; root.custom-menu-index = -1; }
                }
            }

            Rectangle {
                x: 16px;
                y: 212px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                Text {
                    text: "Cancel";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.delete-list-open = false; root.custom-menu-index = -1; }
                }
            }
        }
    }

    edit-list-overlay := Rectangle {
        visible: root.edit-list-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 135;
        background: LocationColors.dark-blue;
        Rectangle {
            width: parent.width;
            height: 72px;
            background: LocationColors.dark-blue;
            LocationIconButton {
                x: 16px;
                y: 20px;
                icon: @image-url("../assets/icons/icon-chevron-left-circle.svg");
                accessible-name: "Back";
                clicked => { root.edit-list-open = false; root.edit-list-index = -1; }
            }

            Text {
                x: 56px;
                y: 24px;
                width: parent.width - 112px;
                height: 24px;
                text: "Edit locations";
                color: LocationColors.white;
                font-family: "Source Sans Pro";
                font-size: 18px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            x: 16px;
            y: 76px;
            width: parent.width - 32px;
            height: 42px;
            text: "Choose locations for this custom list";
            color: LocationColors.white-60;
            font-family: "Open Sans";
            font-size: 12px;
            wrap: word-wrap;
            vertical-alignment: center;
        }

        edit-list-locations := ListView {
            x: 16px;
            y: 126px;
            width: parent.width - 32px;
            height: parent.height - 142px;
            horizontal-scrollbar-policy: always-off;
            vertical-scrollbar-policy: always-off;
            for location in root.custom-list-locations: Rectangle {
                height: 48px;
                background: item-touch.has-hover ? LocationColors.blue-hover : LocationColors.blue;
                Text {
                    x: 16px + location.depth * 20px;
                    width: parent.width - self.x - 56px;
                    height: parent.height;
                    text: location.label;
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Rectangle {
                    x: parent.width - 36px;
                    y: 14px;
                    width: 20px;
                    height: 20px;
                    border-radius: 3px;
                    border-width: 2px;
                    border-color: LocationColors.white-60;
                    background: location.selected ? LocationColors.green : transparent;
                    Text {
                        text: location.selected ? "✓" : "";
                        color: LocationColors.white;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                item-touch := TouchArea {
                    clicked => { root.custom-list-location-toggled(root.edit-list-index, location.source-index, !location.selected); }
                }
            }
        }

        ThinScrollbar {
            x: edit-list-locations.x + edit-list-locations.width - 12px;
            y: edit-list-locations.y;
            width: 12px;
            height: edit-list-locations.height;
            content-height: edit-list-locations.viewport-height;
            visible-height: edit-list-locations.visible-height;
            scroll-y <=> edit-list-locations.viewport-y;
        }
    }

    rename-list-overlay := Rectangle {
        visible: root.rename-list-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        z: 140;
        background: #00000080;
        TouchArea { }

        Rectangle {
            x: 16px;
            y: (parent.height - 240px) / 2;
            width: parent.width - 32px;
            height: 240px;
            border-radius: 12px;
            background: LocationColors.dark-blue;
            Text {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: 18px;
                text: "Edit list name";
                color: LocationColors.white-60;
                font-family: "Open Sans";
                font-size: 12px;
                font-weight: 600;
            }

            Rectangle {
                x: 16px;
                y: 42px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                TextInput {
                    x: 8px;
                    y: 8px;
                    width: parent.width - 16px;
                    height: 24px;
                    text: root.list-name;
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    edited => { root.list-name = self.text; }
                }
            }

            Text {
                x: 16px;
                y: 90px;
                width: parent.width - 32px;
                height: 18px;
                text: "Enter a new name for the list";
                color: LocationColors.white;
                font-family: "Open Sans";
                font-size: 12px;
            }

            Rectangle {
                x: 16px;
                y: 128px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.green;
                opacity: root.list-name != "" ? 1 : 0.4;
                Text {
                    text: "Save";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    enabled: root.list-name != "";
                    clicked => { root.rename-custom-list(root.custom-menu-index, root.list-name); root.rename-list-open = false; root.custom-menu-index = -1; }
                }
            }

            Rectangle {
                x: 16px;
                y: 176px;
                width: parent.width - 32px;
                height: 40px;
                border-radius: 4px;
                background: LocationColors.blue;
                Text {
                    text: "Cancel";
                    color: LocationColors.white;
                    font-family: "Open Sans";
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.rename-list-open = false; root.custom-menu-index = -1; }
                }
            }
        }
    }
}
